# --- Supabase ---
# Project URL + anon key: dashboard -> Settings -> API. PUBLIC values (baked into the bundle);
# they must also exist as GitHub Actions secrets with the same names for the Pages deploy.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Session pooler connection string (dashboard -> Connect -> Session pooler, port 5432).
# SECRET, local-only: used by drizzle-kit migrations and maintenance scripts, never by CI or the site.
# URL-encode special characters in the password (@ -> %40, # -> %23, ...).
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# --- Google Maps (venue map) ---
VITE_GOOGLE_MAPS_API_KEY=your_maps_key

# --- Cloudinary (only for the one-off cloudinary-setup.mjs script) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
