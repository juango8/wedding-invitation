{
  "name": "weding-invitation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node -r ./crypto-polyfill.cjs ./node_modules/vite/bin/vite.js",
    "build": "tsc -b && node -r ./crypto-polyfill.cjs ./node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "preview": "node -r ./crypto-polyfill.cjs ./node_modules/vite/bin/vite.js preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:import": "node -r dotenv/config scripts/import-guests.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "cloudinary": "^2.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/google.maps": "^3.65.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.4.0",
    "postgres": "^3.4.9",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.0"
  }
}
